<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Запись на встречу</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>Запись на встречу</h1>
    <p class="subtitle">Выберите дату и свободное время:</p>
    <p class="tz-note">Время указывается в UTC+3</p>

    <div class="calendar-layout">
      <div class="calendar-left">
        <div class="calendar-header"><%= new Date(dates[0]).toLocaleDateString('ru-RU', { month: 'long', year: 'numeric', timeZone: 'UTC' }) %></div>
        <div class="calendar-grid">
          <div class="cal-day-name">Пн</div>
          <div class="cal-day-name">Вт</div>
          <div class="cal-day-name">Ср</div>
          <div class="cal-day-name">Чт</div>
          <div class="cal-day-name">Пт</div>
          <div class="cal-day-name">Сб</div>
          <div class="cal-day-name">Вс</div>
          <div class="cal-grid-separator"></div>
          <%
            const firstDate = new Date(dates[0] + 'T00:00:00.000Z');
            const startDow = (firstDate.getUTCDay() + 6) % 7;
            for (let pad = 0; pad < startDow; pad++) {
          %>
            <div class="cal-day cal-day-empty"></div>
          <% } %>
          <% dates.forEach(dateStr => {
            const d = new Date(dateStr + 'T00:00:00.000Z');
            const dayNum = d.getUTCDate();
            const isToday = dateStr === today;
          %>
            <div class="cal-day<%= isToday ? ' cal-day-today' : '' %>" data-date="<%= dateStr %>"><%= dayNum %></div>
          <% }) %>
        </div>
      </div>

      <div class="calendar-right">
        <div id="selected-date-header" class="selected-date-header">Выберите дату</div>
        <div id="slots-container" class="slots-grid"></div>
      </div>
    </div>
  </div>

  <div id="modal-overlay" class="modal-overlay" style="display:none">
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="modal-header">
        <div id="modal-title" class="modal-title">Выберите время</div>
        <button type="button" class="modal-close" id="modal-close-btn" aria-label="Закрыть">&times;</button>
      </div>
      <div class="modal-body">
        <p id="modal-time-info" class="modal-time-info"></p>
        <div id="modal-error" class="error-message" style="display:none"></div>
        <form id="modal-form" novalidate>
          <input type="hidden" name="startTime" id="modal-start-time">

          <div class="form-group">
            <label for="modal-guest-name">Имя</label>
            <input type="text" id="modal-guest-name" name="guestName" required>
          </div>

          <div class="form-group">
            <label for="modal-guest-email">Email</label>
            <input type="email" id="modal-guest-email" name="guestEmail" required>
          </div>

          <button type="submit" class="btn btn-full">Забронировать</button>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-link" id="modal-cancel-btn">Выбрать другое время</button>
      </div>
    </div>
  </div>

  <script src="/js/calendar.js"></script>
</body>
</html>